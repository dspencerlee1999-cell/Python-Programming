# Keeps track of the amount of prime numbers the user enters
num = int(input("Enter a positive value: -1 to quit"))
primeCount = 0

while num > 0:
    isPrime = True

    if num <= 1:
        isPrime = False
    else:
        for i in range(2, num):
            if num % i == 0:
                isPrime = False
                break

    if isPrime:
        print(num, "is prime")
        primeCount += 1
    else:
        print(num, "is not prime")

    num = int(input("Enter a positive value: -1 to quit"))

print("Prime Count:", primeCount)
